{
  "name": "@superbhuman/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @superbhuman/shared build && tsc -p tsconfig.build.json",
    "dev": "pnpm --filter @superbhuman/shared build && node src/index.ts",
    "lint": "pnpm --filter @superbhuman/shared build && tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "pnpm --filter @superbhuman/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@superbhuman/shared": "workspace:*",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "vitest": "^3.1.1"
  }
}
